{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "include": [
    "../config/build.json",
    "../config/compiler-msvc.json",
    "../config/generator-ninja.json",
    "../config/platform-windows.json",
    "../config/targets.json"
  ],
  "configurePresets": [
    {
      "name": "Full-x86-64-SSE2-MSVC-Debug",
      "displayName": "Full x86-64 SSE2 MSVC Debug",
      "description": "Debug configuration for x86-64 MSVC with SSE2 support",
