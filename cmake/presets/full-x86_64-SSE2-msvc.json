    },
    {
      "name": "Full-x86-64-SSE2-MSVC-Release",
      "displayName": "Full x86-64 SSE2 MSVC Release",
      "description": "Release configuration for x86-64 MSVC with SSE2 support",
      "inherits": [
        "config-build-full",
        "config-generator-ninja",
        "config-platform-windows",
        "config-compiler-msvc-x86_64-SSE2",
        "config-target-release"
      ]
    },
    {
      "name": "Full-x86-64-SSE2-MSVC-Release-Dist",
      "displayName": "Full x86-64 SSE2 MSVC Release/Dist",
      "description": "Release (distribution) configuration for x86-64 MSVC with SSE2 support",
      "inherits": [
        "config-build-full",
        "config-generator-ninja",
        "config-platform-windows",
        "config-compiler-msvc-x86_64-SSE2",
        "config-target-release-dist"
